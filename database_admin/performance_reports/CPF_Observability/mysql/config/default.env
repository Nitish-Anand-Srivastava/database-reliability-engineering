SNAPSHOT_INTERVAL_MINUTES=30
RETENTION_DAYS=7
RUN_MODE=scheduled
OUTPUT_ROOT=./data
REPORT_WINDOW_MINUTES=30

# Generic target (used by all engines)
DB_HOST=127.0.0.1
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL_MODE=prefer

# MySQL/Aurora/RDS
MYSQL_LOGIN_PATH=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_DATABASE=performance_schema
MYSQL_PASSWORD=

# PostgreSQL/Aurora PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGDATABASE=postgres
PGPASSWORD=

# SQL Server / Azure SQL DB
SQLSERVER_HOST=127.0.0.1
SQLSERVER_PORT=1433
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_DATABASE=master
SQLSERVER_TRUST_CERT=true

# Oracle
ORACLE_CONNECT_STRING=
ORACLE_USER=system
ORACLE_PASSWORD=
ORACLE_HOST=127.0.0.1
ORACLE_PORT=1521
ORACLE_SERVICE=ORCLPDB1

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/admin

# ClickHouse
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Cassandra
CASSANDRA_HOST=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_USER=
CASSANDRA_PASSWORD=
CASSANDRA_KEYSPACE=system

# Cosmos DB (Azure CLI based collection)
COSMOS_SUBSCRIPTION=
COSMOS_RESOURCE_GROUP=
COSMOS_ACCOUNT=

SNAPSHOT_INTERVAL_MINUTES=30
RETENTION_DAYS=7
RUN_MODE=scheduled
OUTPUT_ROOT=./data

# MySQL target connection (used by scripts/run_oneoff.sh)
# Prefer MYSQL_LOGIN_PATH for secure auth via mysql_config_editor.
MYSQL_LOGIN_PATH=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_DATABASE=performance_schema

# Optional: set only if login-path is not used.
# MYSQL_PASSWORD=

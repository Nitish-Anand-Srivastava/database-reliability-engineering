# SQL Server to Azure SQL Hyperscale migration environment template
# Author: Nitish Anand Srivastava

# Source SQL Server
SOURCE_SQL_HOST=ONPREM-SQL01
SOURCE_SQL_PORT=1433
SOURCE_SQL_DATABASE=SalesDB
SOURCE_SQL_AUTH_MODE=Integrated

# Target Azure SQL Hyperscale
TARGET_AZSQL_SERVER=hyperscale-prod.database.windows.net
TARGET_AZSQL_DATABASE=SalesDB
TARGET_AZSQL_USER=migration_user
TARGET_AZSQL_AUTH_MODE=AzureAD

# Azure subscription and resources
AZ_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZ_RESOURCE_GROUP=rg-sql-migration-prod
AZ_LOCATION=eastus2

# Storage staging
AZ_STORAGE_ACCOUNT=migrationstaging01
AZ_STORAGE_CONTAINER=sql-seed
AZ_STORAGE_TIER=Hot

# DMS project settings
DMS_SERVICE_NAME=dms-sql-hyperscale
DMS_PROJECT_NAME=sqlserver-salesdb-hyperscale
DMS_MIGRATION_MODE=Online

# Bulk seed settings
BACKUP_STRIPE_COUNT=16
BULK_LOAD_MAX_PARALLEL_TABLES=24
DISABLE_NONCLUSTERED_INDEX_DURING_SEED=true

# CDC and sync settings
CDC_ENABLED=true
CDC_LAG_TARGET_MINUTES=5
CDC_LAG_ALERT_MINUTES=15
CDC_BATCH_SIZE=10000
REPLAY_BATCH_SIZE=5000

# Validation thresholds
ROW_PARITY_REQUIRED=100
CHECKSUM_MATCH_REQUIRED=99.9
CRITICAL_QUERY_LATENCY_DELTA_MAX=20

# Cutover controls
CUTOVER_MAX_DOWNTIME_MINUTES=90
HYPERCARE_ROLLBACK_WINDOW_HOURS=72

# Logging
MIGRATION_LOG_PATH=logs/migration.log
CDC_LOG_PATH=logs/cdc.log
VALIDATION_LOG_PATH=logs/validation.log

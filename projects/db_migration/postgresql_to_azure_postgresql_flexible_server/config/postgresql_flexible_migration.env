# PostgreSQL -> Azure PostgreSQL Flexible Server migration config
# Author: Nitish Anand Srivastava

SOURCE_HOST=onprem-pg01
SOURCE_PORT=5432
SOURCE_DB=salesdb
SOURCE_USER=migration_user

TARGET_HOST=pg-flex-prod.postgres.database.azure.com
TARGET_PORT=5432
TARGET_DB=salesdb
TARGET_USER=mig_user

AZ_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZ_RESOURCE_GROUP=rg-pg-migration
AZ_LOCATION=eastus2

FULL_LOAD_JOBS=16
CDC_BATCH_SIZE=10000
CDC_LAG_TARGET_MINUTES=5
CDC_LAG_ALERT_MINUTES=15

ROW_PARITY_REQUIRED=100
CHECKSUM_MATCH_REQUIRED=99.9
CUTOVER_MAX_DOWNTIME_MINUTES=90
